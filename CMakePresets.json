{
  "version": 9,
  "cmakeMinimumRequired": {
    "major": 4,
    "minor": 3,
    "patch": 0
  },

  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "installDir": "${sourceDir}/install/${presetName}",
      "warnings": {
        "dev": true,
        "deprecated": true
      }
    },

    {
      "name": "ninja-base",
      "hidden": true,
      "inherits": "base",
      "generator": "Ninja Multi-Config"
    },

    {
      "name": "windows-base",
      "hidden": true,
      "inherits": "ninja-base",
      "cacheVariables": {
        "CMAKE_C_COMPILER":   "cl",
        "CMAKE_CXX_COMPILER": "cl"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },

    {
      "name": "linux-base",
      "hidden": true,
      "inherits": "ninja-base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },

    {
      "name": "windows",
      "displayName": "Windows  ·  Ninja Multi-Config  ·  MSVC  ·  x64",
      "description": "Primary Windows preset. Requires a Developer Command Prompt. Supports import std (VS 17.6+ / MSVC 14.36+).",
      "inherits": "windows-base"
    },

    {
      "name": "linux",
      "displayName": "Linux  ·  Ninja Multi-Config  ·  GCC",
      "description": "All configurations in one tree. Requires GCC 15+ for import std.",
      "inherits": "linux-base",
      "cacheVariables": {
        "CMAKE_C_COMPILER":   "$penv{HOME}/gcc-16/bin/gcc",
        "CMAKE_CXX_COMPILER": "$penv{HOME}/gcc-16/bin/g++",
        "CMAKE_BUILD_RPATH":  "$penv{HOME}/gcc-16/lib64"
      }
    },

    {
      "name": "linux-asan",
      "displayName": "Linux  ·  Ninja Multi-Config  ·  GCC  ·  ASan+UBSan",
      "description": "Sanitizer build: whole program (std module and deps included) under AddressSanitizer + UndefinedBehaviorSanitizer. Driven by verify.sh's sanitizers stage.",
      "inherits": "linux",
      "binaryDir": "${sourceDir}/build/linux-asan",
      "cacheVariables": {
        "CMAKE_CXX_FLAGS": "-fsanitize=address,undefined -fno-omit-frame-pointer",
        "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=address,undefined"
      }
    },

    {
      "name": "linux-coverage",
      "displayName": "Linux  ·  Ninja Multi-Config  ·  GCC  ·  --coverage",
      "description": "Coverage build: gcov instrumentation (--coverage). Advisory; driven by verify.sh's coverage stage and reported via gcovr filtered to first-party source.",
      "inherits": "linux",
      "binaryDir": "${sourceDir}/build/linux-coverage",
      "cacheVariables": {
        "CMAKE_CXX_FLAGS": "--coverage",
        "CMAKE_EXE_LINKER_FLAGS": "--coverage"
      }
    }
  ],

  "buildPresets": [
    {
      "name": "build-base",
      "hidden": true
    },

    {
      "name": "windows-debug",
      "displayName": "Windows  ·  Debug",
      "inherits": "build-base",
      "configurePreset": "windows",
      "configuration": "Debug"
    },
    {
      "name": "windows-dev",
      "displayName": "Windows  ·  RelWithDebInfo",
      "inherits": "build-base",
      "configurePreset": "windows",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "windows-release",
      "displayName": "Windows  ·  Release",
      "inherits": "build-base",
      "configurePreset": "windows",
      "configuration": "Release"
    },

    {
      "name": "linux-debug",
      "displayName": "Linux  ·  Debug",
      "inherits": "build-base",
      "configurePreset": "linux",
      "configuration": "Debug"
    },
    {
      "name": "linux-dev",
      "displayName": "Linux  ·  RelWithDebInfo",
      "inherits": "build-base",
      "configurePreset": "linux",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "linux-release",
      "displayName": "Linux  ·  Release",
      "inherits": "build-base",
      "configurePreset": "linux",
      "configuration": "Release"
    },
    {
      "name": "linux-asan",
      "displayName": "Linux  ·  ASan+UBSan (Debug)",
      "inherits": "build-base",
      "configurePreset": "linux-asan",
      "configuration": "Debug"
    },
    {
      "name": "linux-coverage",
      "displayName": "Linux  ·  Coverage (Debug)",
      "inherits": "build-base",
      "configurePreset": "linux-coverage",
      "configuration": "Debug"
    }
  ]
}